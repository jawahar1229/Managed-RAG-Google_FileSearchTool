# CELL 3: IMPORTS AND SETUP
import os
from google_genai import GenAIClient

# CELL 4: INITIALIZE GOOGLE GENAI CLIENT with SSL options
# You can bypass SSL verification if necessary (not recommended for production)
ssl_context = "your_ssl_context"  # Replace with actual SSL context setup if needed
client = GenAIClient(ssl_options=ssl_context)

# CELL 5: CREATE KNOWLEDGE STORE
knowledge_store = client.create_knowledge_store("my_knowledge_store")

# CELL 6: UPLOAD DOCUMENTS TO KNOWLEDGE STORE
file_paths = ["path/to/document1.pdf", "path/to/document2.pdf"]  # Add your document paths here
for file_path in file_paths:
    with open(file_path, 'rb') as file:
        knowledge_store.upload_document(file, document_name=os.path.basename(file_path))

# CELL 7: DEFINE QUERY FUNCTION

def ask_knowledge_base(query):
    response = knowledge_store.query(query)
    return response

# CELL 8: EXAMPLE USAGE
query = "What is the impact of AI on healthcare?"
response = ask_knowledge_base(query)
print(response)  # This should print the response from your knowledge store based on the query
