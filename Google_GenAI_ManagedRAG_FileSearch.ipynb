 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Jupyter Notebook for Google GenAI Managed RAG File Search\n",
    "\n",
    "This notebook provides functionality for managing RAG (Retrieval-Augmented Generation) with Google GenAI and file search capabilities."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 1: PRE-REQUISITES\n",
    "This notebook requires access to Google Cloud services and necessary API keys. Ensure that you have configured your environment to access Google GenAI."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 2: INSTALL REQUIRED PACKAGES"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install google-genai\n",
    "!pip install pip-system-certs" (if behind a corporate firewall)
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 3: IMPORTS AND SETUP"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from google import genai\n",
    "from google.genai import types\n",
    "import time\n",
    "import pip_system_certs"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 4: INITIALIZE GOOGLE GENAI CLIENT"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# You can bypass SSL verification if necessary (not recommended for production)\n",
    "http_options = types.HttpOptions(
    client_args={'verify': False}  # This tells the underlying client to ignore SSL errors
   )",
    "client = genai.Client(api_key=<<your-api-key>>,http_options=http_options)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 5: CREATE KNOWLEDGE STORE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "knowledge_store = client.file_search_stores.create(
    config={'display_name': 'My-Knowledge-Base'}
)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 6: UPLOAD DOCUMENTS TO KNOWLEDGE STORE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "file_paths = [\"path/to/document1.pdf\", \"path/to/document2.pdf\"]  # Add your document paths here\n",
    "for file_path in file_paths:\n",
    "    with open(file_path, 'rb') as file:\n",
    "        knowledge_store.upload_document(file, document_name=os.path.basename(file_path))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 7: DEFINE QUERY FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def ask_knowledge_base(query):\n",
    "    response = knowledge_store.query(query)\n",
    "    return response"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## CELL 8: EXAMPLE USAGE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query = \"What is the impact of AI on healthcare?\"\n",
    "response = ask_knowledge_base(query)\n",
    "print(response)  # This should print the response from your knowledge store based on the query"
   ]
  }
 ],
